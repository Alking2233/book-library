{
  "kind": "collectionType",
  "collectionName": "books",
  "info": {
    "singularName": "book",
    "pluralName": "books",
    "displayName": "Book"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string"
    },
    "price": {
      "type": "integer"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Description": {
      "type": "text"
    },
    "shortDescription": {
      "type": "string"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "download": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "files"
      ]
    },
    "category_ids": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "books"
    },
    "author": {
      "type": "string"
    },
    "isbn": {
      "type": "string"
    },
    "publisher": {
      "type": "string"
    },
    "publishedDate": {
      "type": "date"
    },
    "pages": {
      "type": "biginteger"
    },
    "stock": {
      "type": "integer"
    },
    "slug": {
      "type": "uid",
      "targetField": "Title"
    },
    "content": {
      "type": "blocks"
    },
    "Available": {
      "type": "boolean",
      "default": true
    }
  }
}
